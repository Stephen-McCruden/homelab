# FILE PATH: roles/prereqs/templates/kubernetes.repo.j2
# PURPOSE: Keep this file at exactly this path inside the Ansible project.
[kubernetes]
name=Kubernetes v{{ kubernetes_minor_version }}
baseurl=https://pkgs.k8s.io/core:/stable:/v{{ kubernetes_minor_version }}/rpm/
enabled=1
gpgcheck=1
repo_gpgcheck=1
gpgkey=https://pkgs.k8s.io/core:/stable:/v{{ kubernetes_minor_version }}/rpm/repodata/repomd.xml.key
exclude={{ kubernetes_exclude_packages }}
